---
Language: Cpp
BasedOnStyle: LLVM
# --- General Indentation ---
IndentWidth: 4
UseTab: Never
ContinuationIndentWidth: 4

# --- Line Breaking & Wrapping ---
# This is the most important setting for fluent interfaces.
# A lower value will cause clang-format to break long chains more often.
# Adjust this value to fit your team's preference.
ColumnLimit: 100

# How to wrap function parameters and arguments
BinPackParameters: false
BinPackArguments: false
AlignAfterOpenBracket: BlockIndent

# --- Braces and Pointers ---
BreakBeforeBraces: Custom
BraceWrapping:
  AfterFunction: true
  AfterControlStatement: true
  BeforeLambdaBody: true
  AfterClass: true
  AfterStruct: true
  AfterEnum: true
PointerAlignment: Right
AllowShortLambdasOnASingleLine: None

# --- Operator Breaking ---
# This ensures that when a line is broken, the operator (like ->)
# is at the beginning of the new line, indented.
BreakBeforeBinaryOperators: All
...
